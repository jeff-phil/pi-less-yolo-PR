#!/usr/bin/env bash
#MISE description="Run pi coding agent in a Docker container"
#MISE raw=true
#MISE dir="{{cwd}}"
set -euo pipefail

# shellcheck source=tasks/pi/_common
source "$(dirname "$0")/_common"

if [ -n "${TMUX:-}" ]; then
  tmux set-option -p allow-passthrough on 2>/dev/null || true
  trap 'tmux set-option -p allow-passthrough off 2>/dev/null || true' EXIT
fi

docker run "${DOCKER_FLAGS[@]}" "${PI_IMAGE}" "$@"
