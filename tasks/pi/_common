# Common setup for pi Docker tasks. Source this file; do not execute directly.
# Usage: source "$(dirname "$0")/_common"

PI_IMAGE="pi-less-yolo:latest"

docker image inspect "${PI_IMAGE}" > /dev/null 2>&1 || mise run pi:build

# Permissions:
#   --user $(id -u):$(id -g)   files created in /workspace are owned by the
#                               calling user on the host, not root.
#   --cap-drop=ALL             drop all Linux capabilities; pi needs none.
#   --no-new-privileges        prevent setuid binaries from gaining privileges.
#
# Mounts:
#   $(pwd):$(pwd)              current directory, mounted at its real host path.
#   ~/.pi/agent:/pi-agent      pi config, credentials, sessions, and managed
#                               binaries from the host. PI_CODING_AGENT_DIR
#                               tells pi to use this path instead of deriving
#                               it from $HOME, sidestepping any HOME-resolution
#                               issues inside the container.
DOCKER_FLAGS=(
  "--rm"
  "--interactive"
  "--user" "$(id -u):$(id -g)"
  "--cap-drop=ALL"
  "--security-opt=no-new-privileges"
  "--volume" "$(pwd):$(pwd)"
  "--volume" "${HOME}/.pi/agent:/pi-agent"
  "--workdir" "$(pwd)"
  "--env" "PI_CODING_AGENT_DIR=/pi-agent"
  "--env" "TERM=${TERM:-xterm-256color}"
  "--env" "COLORTERM=${COLORTERM:-truecolor}"
)

# Forward pi-related env vars and API keys if set on the host.
# Auth file (~/.pi/agent/auth.json) takes priority over these if present.
PI_ENV_VARS=(
  PI_SKIP_VERSION_CHECK
  PI_CACHE_RETENTION
  PI_PACKAGE_DIR
  VISUAL
  EDITOR
  ANTHROPIC_API_KEY
  AZURE_OPENAI_API_KEY
  OPENAI_API_KEY
  GEMINI_API_KEY
  MISTRAL_API_KEY
  GROQ_API_KEY
  CEREBRAS_API_KEY
  XAI_API_KEY
  OPENROUTER_API_KEY
  AI_GATEWAY_API_KEY
  ZAI_API_KEY
  OPENCODE_API_KEY
  KIMI_API_KEY
  MINIMAX_API_KEY
  MINIMAX_CN_API_KEY
)
for var in "${PI_ENV_VARS[@]}"; do
  [ -n "${!var:-}" ] && DOCKER_FLAGS+=("--env" "$var=${!var}")
done

[ -t 0 ] && [ -t 1 ] && DOCKER_FLAGS+=("--tty")

# Git identity: mount ~/.gitconfig read-only so the agent can commit with the
# correct author identity. Opt out by setting PI_NO_GITCONFIG=1.
#
# Note: credential helpers (e.g. osxkeychain, libsecret) referenced in
# ~/.gitconfig will not be available inside the container and will fail
# gracefully — git falls back to prompting for credentials.
if [[ -z "${PI_NO_GITCONFIG:-}" && -f "${HOME}/.gitconfig" ]]; then
  DOCKER_FLAGS+=("--volume" "${HOME}/.gitconfig:/home/piuser/.gitconfig:ro")
fi

# SSH agent forwarding: forward the host SSH agent socket into the container
# so the agent can use SSH-based git remotes without private keys ever
# entering the container. Opt in by setting PI_SSH_AGENT=1.
#
# Security note: a compromised container can authenticate as you to any SSH
# server your agent has loaded. Review loaded keys with `ssh-add -l` before
# enabling. This does not weaken the existing --cap-drop / --user constraints.
#
# On macOS, Docker Desktop exposes the host SSH agent via a fixed path inside
# the VM. On Linux the live socket is bind-mounted directly.
if [[ -n "${PI_SSH_AGENT:-}" ]]; then
  if [[ "$(uname -s)" == "Darwin" ]]; then
    DOCKER_FLAGS+=(
      "--mount" "type=bind,src=/run/host-services/ssh-auth.sock,target=/run/host-services/ssh-auth.sock"
      "--env" "SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock"
    )
  elif [[ -S "${SSH_AUTH_SOCK:-}" ]]; then
    DOCKER_FLAGS+=(
      "--volume" "${SSH_AUTH_SOCK:-}:${SSH_AUTH_SOCK:-}"
      "--env" "SSH_AUTH_SOCK=${SSH_AUTH_SOCK:-}"
    )
  fi
fi
