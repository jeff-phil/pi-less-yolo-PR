#!/usr/bin/env bash
#MISE description="Smoke test that pi:readonly mounts the project directory read-only"
set -euo pipefail

# shellcheck disable=SC2016  # $1 expands inside the container, not here
_inner='
  touch ./__ro_test 2>&1 && { rm -f ./__ro_test; echo WRITABLE; } || echo READONLY
'
result=$(
  _PI_WORKDIR_RO=1 bash -c '
    source tasks/pi/_docker_flags
    docker run "${DOCKER_FLAGS[@]}" pi-less-yolo:latest bash -c "$1"
  ' -- "$_inner"
)

[ "$result" = "READONLY" ] || { echo "FAIL: working directory is not read-only"; exit 1; }
echo "  OK working directory is read-only"
